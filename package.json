    "lint": "eslint dist/js/**/*.js",
    "lint:fix": "eslint dist/js/**/*.js --fix",
    "format": "prettier --write dist/**/*.html dist/js/**/*.js src/scss/**/*.scss",
    "format:check": "prettier --check dist/**/*.html dist/js/**/*.js src/scss/**/*.scss"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cornerstone-CICCC/final-project-clarla-beauty-togo-tatsuya.git"
